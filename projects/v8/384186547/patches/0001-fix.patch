+  // Range errors bailed out earlier; only the failing allocation needs to be
+  // caught here.
+  if (!backing_store) {
+    return {nullptr, MessageTemplate::kArrayBufferAllocationFailed};
+  }
+  return {std::move(backing_store), std::nullopt};
