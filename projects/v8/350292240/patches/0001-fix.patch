diff --git a/src/codegen/arm64/macro-assembler-arm64.cc b/src/codegen/arm64/macro-assembler-arm64.cc
index 1b56955f687..187a51262a7 100644
--- a/src/codegen/arm64/macro-assembler-arm64.cc
