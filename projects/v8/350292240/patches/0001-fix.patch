+
+  constexpr unsigned int kEntrySizeLog2 =
+      std::bit_width(sizeof(wasm::WasmCodePointerTableEntry)) - 1;
+  shlq(target, Immediate(kEntrySizeLog2));
+
+  movq(target, Operand(kScratchRegister, target, ScaleFactor::times_1, 0));
+  call(target);
+}
+
