-bool IsCanonical(double actual) {
-  uint64_t actual_bits = base::bit_cast<uint64_t>(actual);
-  // Canonical NaN has quiet bit and no payload.
-  return (actual_bits & 0xFFF8000000000000) == actual_bits;
-}
