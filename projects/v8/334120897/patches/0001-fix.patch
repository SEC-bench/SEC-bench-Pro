-bool IsExtreme(double x) {
-  double abs_x = std::fabs(x);
-  const double kSmallFloatThreshold = 1.0e-298;
-  const double kLargeFloatThreshold = 1.0e298;
-  return abs_x != 0.0f &&  // 0 or -0 are fine.
