+TEST(CombineCompareWord64Logic2) {
+  CombineCompareLogic2<CombineCompareWord64<2>, uint64_t>(
+      kInt64CmpOpcodes, MachineType::Uint64, ValueHelper::uint64_vector());
+}
+#endif
