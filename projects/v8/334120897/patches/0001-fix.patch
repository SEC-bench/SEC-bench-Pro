+  // Runtime call to table.grow.
+  switchesToCS(wrapper);
+  // No runtime calls.
+  switchesToCS(wrapper2);
+  // Runtime call to allocate the bigint.
+  switchesToCS(wrapper3);
+  // Runtime call for array.new.
+  switchesToCS(wrapper4);
+  %CheckIsOnCentralStack();
+})();
