+++ b/js/src/jit-test/tests/fuses/bug2023024.js
@@ -0,0 +1,13 @@
+var re = /foo/g;
+re.lastIndex = {};
+var obj = Object.create(re);
+
+function read() {
+  return obj.lastIndex;
+}
+
+for (var i = 0; i < 50; i++) read();
+
+re.exec("foofoofoo");
+
+read();
diff --git a/js/src/jit/CacheIR.cpp b/js/src/jit/CacheIR.cpp
