+  uint32_t allocSiteIndex;
+  if (!readAllocSiteIndex(&allocSiteIndex)) {
+    return false;
+  }
 
   if (deadCode_) {
     return true;
@@ -8125,7 +8131,10 @@ bool BaseCompiler::emitArrayNew() {
