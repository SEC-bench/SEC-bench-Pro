From 5ffc1340655f25a8d75c7818b4657b3a5b75ac13 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Andr=C3=A9=20Bargull?= <andre.bargull@gmail.com>
Date: Fri, 22 Oct 2021 08:30:33 +0000
Subject: [PATCH] Bug 1736307: Properly test for string comparisons. r=jandem

Differential Revision: https://phabricator.services.mozilla.com/D128725
---
 js/src/jit-test/tests/auto-regress/bug1736307.js |  3 +++
 js/src/jit/MIR.cpp                               | 12 +++++++-----
 2 files changed, 10 insertions(+), 5 deletions(-)
 create mode 100644 js/src/jit-test/tests/auto-regress/bug1736307.js

diff --git a/js/src/jit-test/tests/auto-regress/bug1736307.js b/js/src/jit-test/tests/auto-regress/bug1736307.js
new file mode 100644
index 000000000000..7fe3cbb6d992
--- /dev/null
+++ b/js/src/jit-test/tests/auto-regress/bug1736307.js
@@ -0,0 +1,3 @@
+for (var i = 0; i < 100; ++i) {
+  assertEq(typeof Uint16Array == undefined, false);
+}
diff --git a/js/src/jit/MIR.cpp b/js/src/jit/MIR.cpp
index 41dcf672dc92..68b3c0303857 100644
--- a/js/src/jit/MIR.cpp
+++ b/js/src/jit/MIR.cpp
@@ -3835,10 +3835,17 @@ static mozilla::Maybe<std::pair<MTypeOfName*, JSType>> IsTypeOfCompare(
   if (!IsEqualityOp(ins->jsop())) {
     return mozilla::Nothing();
   }
+  if (ins->compareType() != MCompare::Compare_String) {
+    return mozilla::Nothing();
+  }
 
   auto* lhs = ins->lhs();
   auto* rhs = ins->rhs();
 
+  MOZ_ASSERT(ins->type() == MIRType::Boolean);
+  MOZ_ASSERT(lhs->type() == MIRType::String);
+  MOZ_ASSERT(rhs->type() == MIRType::String);
+
   if (!lhs->isTypeOfName() && !rhs->isTypeOfName()) {
     return mozilla::Nothing();
   }
@@ -3846,11 +3853,6 @@ static mozilla::Maybe<std::pair<MTypeOfName*, JSType>> IsTypeOfCompare(
     return mozilla::Nothing();
   }
 
-  MOZ_ASSERT(ins->compareType() == MCompare::Compare_String);
-  MOZ_ASSERT(ins->type() == MIRType::Boolean);
-  MOZ_ASSERT(lhs->type() == MIRType::String);
-  MOZ_ASSERT(rhs->type() == MIRType::String);
-
   auto* typeOfName =
       lhs->isTypeOfName() ? lhs->toTypeOfName() : rhs->toTypeOfName();
   MOZ_ASSERT(typeOfName->input()->isTypeOf());
-- 
2.43.0

