FROM hwiwonlee/sm.base:latest

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Seoul
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV SRC=/src
ENV SHELL=/bin/bash

ENV SANITIZER="address"
ENV ARCHITECTURE="x86_64"

ENV OUT=/out

RUN ln -sf /usr/local/bin/python3 /usr/bin/python || true
RUN apt-get update && apt-get install -y python3-venv python3-pip
ENV PATH="/root/.mozbuild/cbindgen:/root/.cargo/bin:${PATH}"

WORKDIR $SRC/gecko-dev

# Vulnerable revision: parent of fix 5461a647546a79ff479804263a3b7ef114eaf0f7
# Bug 1810711 / CVE-2023-25735 (sec-high, MFSA 2023-05) —
# js::FindErrorInstanceOrPrototype (js/src/vm/ErrorObject.cpp) walks the
# prototype chain of a JSObject looking for an Error prototype. The
# original code unwrapped once and then advanced via GetPrototype on the
# unwrapped target; a Proxy getPrototypeOf trap could return a
# cross-compartment object, leaving the subsequent IsErrorProtoKey lookup
# operating on a stale / wrong-compartment pointer — use-after-free on
# err.stack read.
# Fix author: Iain Ireland, 2023-01-24
RUN git checkout 5461a647546a79ff479804263a3b7ef114eaf0f7~1

# Patch ExclusiveData.h — clang 19 rejects the 2023-era self-move constructor.
RUN python3 - <<'PYEOF'
import re
f = 'js/src/threading/ExclusiveData.h'
t = open(f).read()
pattern = re.compile(
  r'ExclusiveData\(ExclusiveData&&\s*rhs\)\s*(?:.|\n)*?'
  r'MOZ_ASSERT\(&rhs != this, "self-move disallowed!"\);\s*\}\s*'
  r'(?:\n\s*)*'
  r'ExclusiveData&\s*operator=\(ExclusiveData&&\s*rhs\)\s*\{(?:.|\n)*?'
  r'return \*this;\s*\}',
  re.MULTILINE
)
replacement = 'ExclusiveData(ExclusiveData&&) = delete;\n  ExclusiveData& operator=(ExclusiveData&&) = delete;'
t2 = pattern.sub(replacement, t)
assert t != t2, "ExclusiveData.h move ctor regex did not match"
open(f, 'w').write(t2)
PYEOF

# Build 1: ASAN+debug (for crash verification)

# Apply the upstream fix patch(es) on top of the vulnerable revision.
COPY patches/ /tmp/secb-fix-patches/
RUN set -eux; for p in /tmp/secb-fix-patches/*.patch; do git apply "$p"; done

RUN rm -f mozconfig .mozconfig && cat > .mozconfig <<'EOF'
ac_add_options --enable-address-sanitizer
ac_add_options --disable-jemalloc
ac_add_options --enable-optimize="-O1"
ac_add_options --enable-debug
ac_add_options --enable-debug-symbols
ac_add_options --enable-application=js
ac_add_options --disable-bootstrap
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj-debug-asan
EOF
RUN ./mach build

# Build 2: Release (for normal execution)
RUN rm -f mozconfig .mozconfig && cat > .mozconfig <<'EOF'
ac_add_options --enable-optimize
ac_add_options --disable-debug
ac_add_options --enable-application=js
ac_add_options --disable-bootstrap
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj-release
EOF
RUN ./mach build

RUN mkdir -p /out
RUN ln -sf $SRC/gecko-dev/obj-debug-asan/dist/bin/js /out/js
RUN ln -sf $SRC/gecko-dev/obj-release/dist/bin/js /out/js-release

COPY build.sh $SRC/
COPY secb.sh /usr/local/bin/secb

RUN chmod +x $SRC/build.sh
RUN chmod +x /usr/local/bin/secb
RUN mkdir -p /app/artifacts
RUN mkdir -p /testcase

# Install Node.js, latest npm, and OpenAI Codex
RUN curl -fsSL https://deb.nodesource.com/setup_current.x | bash - && \
  apt-get install -y nodejs
RUN npm i -g npm@latest @openai/codex

RUN ln -s /usr/bin/make /usr/bin/gmake || true

# Install beads
RUN npm install -g @beads/bd@0.50.2 || true

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# API KEY config entrypoint
RUN apt-get update && apt-get install -y gettext-base
RUN cat > /entrypoint.sh <<'ENTRYEOF'
#!/bin/bash
mkdir -p /root/.codex
cat <<EOT | envsubst > /root/.codex/auth.json
{
  "OPENAI_API_KEY": "${OPENAI_API_KEY}",
  "model": "gpt-5-mini",
  "provider": "openai"
}
EOT
exec "$@"
ENTRYEOF

# Install Claude Code
ENV PATH="/root/.local/bin:${PATH}"
RUN curl -fsSL https://claude.ai/install.sh | bash

RUN bd init || true

RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
