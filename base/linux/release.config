# Release-style universal kernel config additions.
#
# This file is baked into the base image at /base/release.config and applied
# by every per-CVE build.sh before config/kernel.config.additions, on top of
# `make x86_64_defconfig`.

# Panic-on-oops ladder + frame pointer for useful backtraces.
CONFIG_DEBUG_KERNEL=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=-1
CONFIG_FRAME_POINTER=y

# Full DWARF5 debug info for symbol resolution.
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF5=y

# Relax -Werror so tools/ and drivers compile under newer host toolchains.
# CONFIG_WERROR is not set

# Memory-safety sanitizer baseline used by the validated Linux instances.
CONFIG_KASAN=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_INLINE=y
CONFIG_KASAN_VMALLOC=y

# User namespaces for CAP_NET_ADMIN-gated PoCs.
CONFIG_USER_NS=y
